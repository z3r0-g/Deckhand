# ========================================
# Deckhand Configuration
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# OPTIONAL: UI Mode
# fun (default) or pro
DECKHAND_UI_MODE=fun

# OPTIONAL: Database Path
# Default: deckhand.db (in working directory)
DATABASE_PATH=deckhand.db

# OPTIONAL: Flask Secret Key
# Change this in production for security
SECRET_KEY=dev-key-change-in-production

# --- Orchestration Providers ---
# Deckhand is zero-config for the local Docker socket (/var/run/docker.sock).
# Enable additional providers below.

# Native Docker (Remote API)
# DOCKER_HOST=tcp://10.0.0.5:2375

# Portainer Integration
# PORTAINER_URL=https://your-portainer-host:9000
# PORTAINER_API_KEY=ptr_your_api_key_here

# Dockge Integration
# DOCKGE_URL=http://dockge:5001
# DOCKGE_API_KEY=your_dockge_api_key
